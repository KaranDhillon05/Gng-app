PORT=4000
APP_ORIGIN=http://localhost:8081
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-secret
OTP_TTL_SECONDS=300
OTP_MAX_VERIFY_ATTEMPTS=5

# MSG91 settings
# Add your auth key from MSG91 dashboard.
MSG91_AUTH_KEY=your-msg91-auth-key

# Template ID for OTP route.
# You can leave this empty for initial testing if your account/setup allows.
MSG91_TEMPLATE_ID=

# Sender ID approved via DLT for production SMS in India.
MSG91_SENDER=
